{
  "_comment": "loom adds the following stanzas to ~/.claude/settings.json. install.sh merges them in (idempotent, additive). The full settings.json file is NOT owned by loom — only these stanzas. Permissions are read-only / safe operations needed by loom's hooks + scripts; the bd:* permission lets bd subcommands run without prompts.",

  "permissions": {
    "allow": [
      "Bash(bd:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git worktree list:*)",
      "mcp__mempalace__mempalace_status",
      "mcp__mempalace__mempalace_kg_stats",
      "mcp__mempalace__mempalace_kg_query",
      "mcp__mempalace__mempalace_kg_timeline",
      "mcp__mempalace__mempalace_search",
      "mcp__mempalace__mempalace_get_drawer",
      "mcp__mempalace__mempalace_list_drawers",
      "mcp__mempalace__mempalace_list_rooms",
      "mcp__mempalace__mempalace_list_wings",
      "mcp__mempalace__mempalace_get_taxonomy",
      "mcp__mempalace__mempalace_diary_read",
      "mcp__mempalace__mempalace_check_duplicate",
      "mcp__mempalace__mempalace_traverse",
      "mcp__mempalace__mempalace_find_tunnels",
      "mcp__mempalace__mempalace_follow_tunnels",
      "mcp__mempalace__mempalace_list_tunnels",
      "mcp__mempalace__mempalace_graph_stats",
      "mcp__mempalace__mempalace_memories_filed_away",
      "mcp__mempalace__mempalace_get_aaak_spec"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "bash $HOME/.claude/hooks/bd-claim-research.sh"},
          {"type": "command", "command": "bash $HOME/.claude/hooks/bd-close-capture.sh"},
          {"type": "command", "command": "bash $HOME/.claude/hooks/git-push-bd-sync.sh"}
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {"type": "command", "command": "bash $HOME/.claude/hooks/workflow-mode-onboarding.sh"}
        ]
      }
    ]
  },

  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/scripts/statusline.sh",
    "padding": 0
  }
}
