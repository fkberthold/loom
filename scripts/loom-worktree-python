#!/usr/bin/env bash
# loom-worktree-python — `python3` wrapper that prepends the linked
# worktree's toplevel to PYTHONPATH so the worktree's source wins
# sys.path resolution over a shadowing `pip install -e <main>`
# editable install.
#
# Closes loom-rsk (Mode 5 of the worktree-isolation failure cluster).
# When MAIN has been registered as an editable install (e.g.
# `pip install -e ~/repos/<project>` at any point), its site-packages
# .pth entry puts MAIN's source on sys.path. Workers dispatched into
# a `.claude/worktrees/agent-<id>/` worktree that invoke `python3`
# (directly or via pytest, which uses its own rootdir resolution)
# get MAIN's modules instead of the worktree's modifications. Tests
# pass against MAIN's behavior; the worktree's changes don't actually
# get exercised. Silent and post-merge-only.
#
# The wrapper resolves the worktree toplevel via git plumbing and
# prepends it to PYTHONPATH before execing python3 — so the worktree
# copy always wins regardless of caller cwd.
#
# Usage:
#   loom-worktree-python <python-args...>
#
# Behavior:
#   1. Refuses to run in the main working tree (or outside any git
#      tree). In the main tree the shadow doesn't apply — use plain
#      `python3` there.
#   2. Prepends "<worktree-toplevel>:" to PYTHONPATH (preserving any
#      existing PYTHONPATH suffix).
#   3. `exec python3 "$@"` — the wrapper's exit code is python3's.
#
# Exit code:
#   - Passes through python3's exit code.
#   - 2 = wrapper-level refusal (e.g. not in a linked worktree).

set -uo pipefail

# --- Resolve git context ---------------------------------------------------

TOPLEVEL=$(git rev-parse --show-toplevel 2>/dev/null) || {
  echo "loom-worktree-python: not inside a git working tree" >&2
  exit 2
}
COMMON_DIR=$(git rev-parse --git-common-dir 2>/dev/null) || {
  echo "loom-worktree-python: cannot resolve git common dir" >&2
  exit 2
}
if [ "${COMMON_DIR#/}" = "$COMMON_DIR" ]; then
  COMMON_DIR=$(cd "$TOPLEVEL" && cd "$COMMON_DIR" && pwd)
fi
MAIN_DIR=$(dirname "$COMMON_DIR")

if [ "$TOPLEVEL" = "$MAIN_DIR" ]; then
  echo "loom-worktree-python: refusing — current directory is the main working tree, not a linked worktree. Use plain 'python3' there (the editable-install shadow does not apply in main)." >&2
  exit 2
fi

# --- Prepend worktree toplevel to PYTHONPATH ------------------------------

if [ -n "${PYTHONPATH:-}" ]; then
  export PYTHONPATH="$TOPLEVEL:$PYTHONPATH"
else
  export PYTHONPATH="$TOPLEVEL"
fi

# --- Exec python3 ---------------------------------------------------------

exec python3 "$@"
