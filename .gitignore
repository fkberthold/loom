# Per-installation symlinks created by install.sh (none of loom's files;
# the symlinks live in ~/.claude/, not here).

# bd state intentionally COMMITTED (issues.jsonl is the cross-session source of truth).
# But interactions.jsonl is a per-session log.
.beads/interactions.jsonl

# Defensive: bd's pre-commit hook can re-export issues.jsonl to a stray
# path at repo / worktree root (loom-22h: the worktree-mode export bug).
# The canonical export path is .beads/issues.jsonl; any root-level
# issues.jsonl is the bug's footprint, not real state.
/issues.jsonl

# Per-session ephemera if loom itself is being worked on
.claude/workflow-state.json

# Per-project audit memo state — written by /audit-project to remember
# user "skip" answers across runs so the same row doesn't re-prompt.
# Never read by anything except the audit-project skill. (loom-r6g)
.claude/loom-audit-state.json

# Editor / OS
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/

# Worktrees (per CLAUDE.md convention)
.worktrees/

# Per-subagent worktrees created by `Agent` tool with isolation:"worktree".
# Auto-cleaned by the harness on session exit; never tracked.
# Loom convention: project-onboarder item 11 checks for this entry.
.claude/worktrees/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# MkDocs build output + local docs venv
/site/
/.venv-docs/

# bd-worktree-preseed sentinel (loom-x4m hook memoization, ephemeral per worktree).
.beads/.loom-preseeded

# install.sh / /audit-project pre-loom backups — per-installation
# snapshots of user-local files that install.sh / the audit-project
# autofix recipes overwrote on first run. Never tracked; the canonical
# state lives at the un-suffixed path. (loom-7ro)
*.pre-loom.bak
