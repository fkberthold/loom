# Per-installation symlinks created by install.sh (none of loom's files;
# the symlinks live in ~/.claude/, not here).

# bd state intentionally COMMITTED (issues.jsonl is the cross-session source of truth).
# But interactions.jsonl is a per-session log.
.beads/interactions.jsonl

# Defensive: bd's pre-commit hook can re-export issues.jsonl to a stray
# path at repo / worktree root (loom-22h: the worktree-mode export bug).
# The canonical export path is .beads/issues.jsonl; any root-level
# issues.jsonl is the bug's footprint, not real state.
/issues.jsonl

# Per-session ephemera if loom itself is being worked on
.claude/workflow-state.json

# Editor / OS
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/

# Worktrees (per CLAUDE.md convention)
.worktrees/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
